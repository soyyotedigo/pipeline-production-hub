# App
APP_ENV=development

# PostgreSQL
POSTGRES_USER=vfxhub
POSTGRES_PASSWORD=vfxhub_pass
POSTGRES_DB=vfxhub
DATABASE_URL=postgresql://vfxhub:vfxhub_pass@db:5432/vfxhub

# Redis
REDIS_URL=redis://redis:6379/0
TASK_QUEUE_NAME=tasks:queue:default
TASK_STATUS_TTL_SECONDS=86400
METRICS_ACTIVE_USERS_WINDOW_MIN=15

# JWT
JWT_SECRET=changeme_super_secret_key
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MIN=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Auth hashing
BCRYPT_ROUNDS=12
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MIN=15

# General API rate limit (fixed window per user/IP)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Seed (optional)
SEED_ADMIN_EMAIL=admin@vfxhub.dev
SEED_ADMIN_PASSWORD=admin123
SEED_DEMO_PROJECT_NAME=Demo Project
SEED_DEMO_PROJECT_CODE=DEMO

# Storage (MinIO)
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=./data/storage
STORAGE_URL_EXPIRES_DEFAULT=3600
STORAGE_MAX_UPLOAD_SIZE_BYTES=1073741824
PROJECT_EXPORT_ASYNC_THRESHOLD_ENTITIES=1000

S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=pipeline-production-hub
S3_REGION=us-east-1
