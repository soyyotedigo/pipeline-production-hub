meta {
  name: 07 Patch Webhook
  type: http
  seq: 7
}

patch {
  url: {{baseUrl}}/webhooks/{{webhookId}}
  body: json
  auth: none
}

headers {
  content-type: application/json
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "events": [
      "status.changed",
      "assignment.changed"
    ]
  }
}

tests {
  test("patch webhook returns 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
