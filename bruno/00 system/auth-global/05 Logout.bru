meta {
  name: 05 Logout
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/auth/logout
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "refresh_token": "{{refreshToken}}"
  }
}

tests {
  test("logout returns 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
