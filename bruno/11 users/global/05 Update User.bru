meta {
  name: 05 Update User
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/users/{{newUserId}}
  body: json
  auth: none
}

headers {
  content-type: application/json
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "display_name": "{{updatedDisplayName}}"
  }
}

script:pre-request {
  bru.setVar("updatedDisplayName", `Updated ${bru.getVar("newUserDisplayName")}`);
}

tests {
  test("update user returns 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
