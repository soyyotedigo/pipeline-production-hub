meta {
  name: 06 Attach Tag To Shot
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/shots/{{shotId}}/tags
  body: json
  auth: none
}

headers {
  content-type: application/json
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "tag_id": "{{tagId}}"
  }
}

tests {
  test("attach tag returns 201", function() {
    expect(res.getStatus()).to.equal(201);
  });
}
