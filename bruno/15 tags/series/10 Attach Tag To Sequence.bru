meta {
  name: 10 Attach Tag To Sequence
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/sequences/{{sequenceId}}/tags
  body: json
  auth: none
}

headers {
  content-type: application/json
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "tag_id": "{{tagId}}"
  }
}

tests {
  test("attach tag to sequence returns 201", function() {
    expect(res.getStatus()).to.equal(201);
  });
}
